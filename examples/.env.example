# Spectron credentials. The API key is a secret — Hermes writes it to .env when
# you run `hermes memory setup`. Copy to `.env` and fill in for local runs.

SPECTRON_API_KEY=
SPECTRON_ENDPOINT=https://your-instance.spectron.dev
SPECTRON_CONTEXT=my-context

# Optional (otherwise sourced from spectron.json / defaults):
# SPECTRON_RECALL_MODE=hybrid
# SPECTRON_WRITE_FREQUENCY=turn
# SPECTRON_TOP_K=5
# SPECTRON_DEFAULT_SCOPE=user/tobie
